import MultiNeuron.Basic.Network
namespace Net

noncomputable section

/-- Consists of an affine layer that depends only on the first input coordinate, maps [a,b] to [-1,1] -/
def normalize1DNet {d : Nat} (a b : Real) : Net (Nat.succ d) 1 :=
  Net.affineLayer (Matrix.single 0 0 (2 / (b - a))) ![-(a + b) / (b - a)]

/-- Maps `z` to `(z + 1, z)`. -/
def liftNet : Net 1 2 :=
  Net.affineLayer !![1; 1] ![1, 0]

/-- affine map, maps (x, y) to (x - 1, -x + 1, y - 0.5, -y + 0.5). -/
def absNet : Net 2 4 :=
  Net.affineLayer !![1, 0; -1, 0; 0, 1; 0, -1] ![-1, 1, -(1 / 2 : Real), (1 / 2 : Real)]

/-- Sum the four coordinates with common coefficient `c`. -/
def sumNet (c : Real) : Net 4 1 :=
  Net.affineLayer !![c, c, c, c] 0

/-- Computes the function `f'(x,y) = 2*T*|x-1| + 2*T*|y-0.5|` in the proof of Theorem 3.3 in the paper. -/
def valleyNet (T : Real) : Net 2 1 :=
  Net.comp absNet (Net.comp (Net.reluLayer 4) (sumNet (2 * T)))

/-- Computes the function `f(x,y) = -2*T*|x-1| - 2*T*|y-0.5|`. -/
def negValleyNet (T : Real) : Net 2 1 :=
  Net.comp absNet (Net.comp (Net.reluLayer 4) (sumNet (-2 * T)))


/--
Prefix net: maps the input set to the set
`{(x,y): 0 ≤ x ≤ 1, y = 0} ∪ {(x,y): 1 ≤ x ≤ 2, y = x - 1}`.
-/
def prefixNet {d : Nat} (a b : Real) : Net (Nat.succ d) 2 :=
  Net.comp (normalize1DNet (d := d) a b) (Net.comp liftNet (Net.reluLayer 2))

/-- Prefix net composed with the valley net. -/
def lowerCounterexample {d : Nat} (a b T : Real) : Net (Nat.succ d) 1 :=
  Net.comp (prefixNet (d := d) a b) (valleyNet T)

/-- Prefix net composed with the negative valley net. -/
def upperCounterexample {d : Nat} (a b T : Real) : Net (Nat.succ d) 1 :=
  Net.comp (prefixNet (d := d) a b) (negValleyNet T)


/-- Scalar normalization formula underlying `normalize1DNet`. -/
def normalized (a b x : Real) : Real :=
  (2 * x - (a + b)) / (b - a)

/-- A point on the broken line generated by the prefix net. -/
def prefixPoint (t : Real) : Coord 2 :=
  ![max (t + 1) 0, max t 0]

/-- The exact functional value of the valleyNet. -/
def valleyValue (T : Real) (y : Coord 2) : Real :=
  2 * T * max (y 0 - 1) 0 + 2 * T * max (1 - y 0) 0 +
    2 * T * max (y 1 - (1 / 2 : Real)) 0 + 2 * T * max ((1 / 2 : Real) - y 1) 0

def leftPoint : Coord 2 := ![0, 0]

def rightPoint : Coord 2 := ![2, 1]

def midPoint : Coord 2 := ![1, 1 / 2]



theorem eval_normalize1DNet {d : Nat} (a b : Real) (x : Coord (Nat.succ d)) :
    eval (normalize1DNet (d := d) a b) x 0 = normalized a b (x 0) := by
  have hmul :
      (Matrix.single (0 : Fin 1) (0 : Fin (Nat.succ d)) (2 / (b - a))).mulVec x 0 =
        (2 / (b - a)) * x 0 := by
    simpa using congrFun
      (Matrix.single_mulVec (i := (0 : Fin 1)) (j := (0 : Fin (Nat.succ d))) (c := (2 / (b - a))) x) 0
  simp [normalize1DNet, normalized, Net.eval, affinemap, hmul]
  ring_nf

theorem eval_liftNet (z : Coord 1) :
    eval liftNet z = ![z 0 + 1, z 0] := by
  have hz : z = ![z 0] := by
    ext j
    fin_cases j
    rfl
  rw [hz]
  ext i
  fin_cases i <;> norm_num [liftNet, Net.eval, affinemap, Matrix.mulVec]

theorem eval_absNet (y : Coord 2) :
    eval absNet y = ![y 0 - 1, 1 - y 0, y 1 - (1 / 2 : Real), (1 / 2 : Real) - y 1] := by
  have hy : y = ![y 0, y 1] := by
    ext j
    fin_cases j <;> rfl
  rw [hy]
  ext i
  fin_cases i <;> norm_num [absNet, Net.eval, affinemap, Matrix.mulVec] <;> ring

theorem eval_sumNet (c : Real) (z : Coord 4) :
    eval (sumNet c) z 0 = c * z 0 + c * z 1 + c * z 2 + c * z 3 := by
  have hz : z = ![z 0, z 1, z 2, z 3] := by
    ext j
    fin_cases j <;> rfl
  rw [hz]
  simp [sumNet, Net.eval, affinemap]
  ring_nf

theorem eval_prefixNet {d : Nat} (a b : Real) (x : Coord (Nat.succ d)) :
    eval (prefixNet (d := d) a b) x = prefixPoint (normalized a b (x 0)) := by
  ext i
  fin_cases i
  · simp [prefixNet, prefixPoint, eval_normalize1DNet, eval_liftNet, Net.eval, normalized, relu]
  · simp [prefixNet, prefixPoint, eval_normalize1DNet, eval_liftNet, Net.eval, normalized, relu]

theorem eval_valleyNet (T : Real) (y : Coord 2) :
    eval (valleyNet T) y 0 = valleyValue T y := by
  simp [valleyNet, valleyValue, Net.eval, eval_absNet, eval_sumNet, relu]

theorem eval_negValleyNet (T : Real) (y : Coord 2) :
    eval (negValleyNet T) y 0 = -valleyValue T y := by
  simp [negValleyNet, valleyValue, Net.eval, eval_absNet, eval_sumNet, relu]
  ring


theorem normalized_mem_Icc {a b x : Real} (hab : a < b) (hx : x ∈ Set.Icc a b) :
    normalized a b x ∈ Set.Icc (-1 : Real) 1 := by
  have hden : 0 < b - a := sub_pos.mpr hab
  constructor
  · rw [normalized]
    field_simp [hden.ne']
    linarith [hx.1]
  · rw [normalized]
    field_simp [hden.ne']
    linarith [hx.2]

theorem normalized_left {a b : Real} (hab : a < b) : normalized a b a = -1 := by
  have hden : b - a ≠ 0 := sub_ne_zero.mpr (ne_of_gt hab)
  rw [normalized]
  field_simp [hden]
  ring



theorem normalized_right {a b : Real} (hab : a < b) : normalized a b b = 1 := by
  have hden : b - a ≠ 0 := sub_ne_zero.mpr (ne_of_gt hab)
  rw [normalized]
  field_simp [hden]
  ring


theorem valleyValue_nonneg (T : Real) (hT : 0 ≤ T) (y : Coord 2) :
    0 ≤ valleyValue T y := by
  have h1 : 0 ≤ 2 * T * max (y 0 - 1) 0 := by positivity
  have h2 : 0 ≤ 2 * T * max (1 - y 0) 0 := by positivity
  have h3 : 0 ≤ 2 * T * max (y 1 - (1 / 2 : Real)) 0 := by positivity
  have h4 : 0 ≤ 2 * T * max ((1 / 2 : Real) - y 1) 0 := by positivity
  dsimp [valleyValue]
  linarith


theorem valleyValue_at_midPoint (T : Real) :
    valleyValue T midPoint = 0 := by
  norm_num [valleyValue, midPoint]
